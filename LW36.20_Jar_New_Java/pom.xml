            <plugin>
                <groupId>LV01.50</groupId>
                <artifactId>cmb-code-quality-maven-plugin</artifactId>
                <version>1.1.4</version>
                <executions>
                    <execution>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <!--  扫描排除文件地址，支持通配符  -->
                    <checkstyleExcludes>
                        <checkstyleExclude>**/src/test/**</checkstyleExclude>
                    </checkstyleExcludes>

                    <!-- 其他配置都请加到Configuration下面  -->

                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.2.0</version>
                <configuration>
                    <excludes>
                        <exclude>
                            /com/cmb/xft/test/
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <skip>true</skip>
                </configuration>
            </plugin>
        </plugins>
    </build>
