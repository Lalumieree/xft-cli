{
  "name": "xft-openapi-cli",
  "version": "2.0.4",
  "description": "TypeScript SDK and CLI for executing XFT OpenAPI feature-call requests.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "xft-openapi-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "sdk",
    "openapi",
    "xft",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lalumieree/xft-cli.git"
  },
  "homepage": "https://github.com/Lalumieree/xft-cli/tree/main/cli",
  "bugs": {
    "url": "https://github.com/Lalumieree/xft-cli/issues"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "sm-crypto": "^0.4.0"
  }
}
