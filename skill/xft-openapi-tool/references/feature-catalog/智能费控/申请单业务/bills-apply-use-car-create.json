{
  "id": "apply-use-car-create",
  "name": "新建用车申请单（草稿、审批通过、审批中）",
  "module": "智能费控",
  "submodule": "申请单业务",
  "operation": "create",
  "resource": "useCarApplication",
  "aliases": [
    "新建用车申请单",
    "创建用车申请单",
    "use car apply create"
  ],
  "keywords": [
    "用车申请单",
    "创建",
    "eventNumber",
    "empNumber",
    "billStatus",
    "useCarInfo"
  ],
  "businessScenarios": [
    "新建草稿用车申请单",
    "新建审批通过用车申请单",
    "新建审批中用车申请单"
  ],
  "description": "新增用车申请单，支持创建草稿、审批通过和审批中三种状态，可携带自定义字段和用车信息。",
  "method": "POST",
  "url": "https://api.cmbchina.com/itrip/xft-api/v1/bills/apply/use-car/create",
  "requestMode": "json",
  "responseMode": "json",
  "encryptBody": true,
  "decryptResponse": true,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "eventNumber": {
        "type": "string",
        "required": true,
        "description": "单据表单编号"
      },
      "outRelId": {
        "type": "string",
        "required": false,
        "description": "外部单据编号"
      },
      "empNumber": {
        "type": "string",
        "required": true,
        "description": "申请人薪福通花名册员工号"
      },
      "billDepartmentCode": {
        "type": "string",
        "required": false,
        "description": "薪福通部门组织编码"
      },
      "billCompanyCode": {
        "type": "string",
        "required": false,
        "description": "薪福通法人公司编码"
      },
      "billStatus": {
        "type": "string",
        "required": true,
        "description": "单据状态：DRAFT 草稿；APPRV 审批通过；APPRV_PEND 审批中",
        "enum": [
          "DRAFT",
          "APPRV",
          "APPRV_PEND"
        ]
      },
      "customFieldValues": {
        "type": "array",
        "required": false,
        "description": "自定义字段值列表",
        "items": {
          "type": "object",
          "properties": {
            "fieldNumber": {
              "type": "string",
              "description": "自定义字段编号"
            },
            "fieldValue": {
              "type": "string",
              "description": "自定义字段值"
            }
          }
        }
      },
      "useCarInfo": {
        "type": "object",
        "required": false,
        "description": "用车信息对象"
      }
    }
  },
  "responseNotes": [
    "成功时 returnCode 为 SUC0000",
    "body 为新创建的单据编号",
    "错误码：E0001 表示具体业务异常提示"
  ],
  "catalogIndex": {
    "path": "../../index.json"
  }
}
