{
  "id": "bills-apply-travel-create",
  "name": "新建差旅申请单（草稿、审批通过、审批中）",
  "module": "智能费控",
  "submodule": "申请单业务",
  "operation": "create",
  "resource": "travelApplication",
  "aliases": [
    "新建差旅申请单",
    "创建差旅申请单",
    "新增差旅申请单",
    "差旅申请单创建",
    "travel create"
  ],
  "keywords": [
    "差旅",
    "申请单",
    "新建",
    "创建",
    "草稿",
    "审批通过",
    "审批中",
    "eventNumber",
    "empNumber",
    "billStatus",
    "businessTrip",
    "spreadInfo"
  ],
  "businessScenarios": [
    "新建草稿状态的差旅申请单",
    "新建审批通过状态的差旅申请单",
    "新建审批中状态的差旅申请单",
    "创建带行程和自定义字段的差旅申请单"
  ],
  "description": "新增差旅申请单，支持通过 billStatus 创建草稿、审批通过和审批中三种状态的单据，可携带自定义字段、行程信息、预估费用、同行人、关联单据和分摊信息。联调已验证 eventNumber 需要传该表单的固定表单编号，而不是每次调用时新生成的流水号。",
  "method": "POST",
  "url": "https://api.cmbchina.com/itrip/xft-api/v1/bills/apply/travel/create",
  "requestMode": "json",
  "responseMode": "json",
  "encryptBody": true,
  "decryptResponse": true,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "eventNumber": {
        "type": "string",
        "required": true,
        "description": "单据表单编号；与具体表单模板一一对应。联调已验证这里要传表单的固定编号，例如“福州auto申请”使用 01260319095833000001；不要传临时生成的业务流水号，否则可能返回“表单已被删除”"
      },
      "outRelId": {
        "type": "string",
        "required": false,
        "description": "外部单据编号"
      },
      "billCompanyCode": {
        "type": "string",
        "required": false,
        "description": "薪福通法人公司编码；不传默认取申请人所属公司，与申请人所属公司不一致时单据部门编号必传"
      },
      "billDepartmentCode": {
        "type": "string",
        "required": false,
        "description": "薪福通部门组织编码；不传默认取申请人所属部门，与申请人所属部门不一致时单据公司编号必传"
      },
      "empNumber": {
        "type": "string",
        "required": true,
        "description": "申请人薪福通花名册员工号"
      },
      "billStatus": {
        "type": "string",
        "required": true,
        "description": "单据状态：DRAFT 草稿；APPRV 审批通过；APPRV_PEND 审批中",
        "enum": [
          "DRAFT",
          "APPRV",
          "APPRV_PEND"
        ]
      },
      "customFieldValues": {
        "type": "array",
        "required": false,
        "description": "自定义字段值列表",
        "items": {
          "type": "object",
          "properties": {
            "fieldNumber": {
              "type": "string",
              "description": "自定义字段编号"
            },
            "fieldValue": {
              "type": "string",
              "description": "自定义字段值"
            }
          }
        }
      },
      "businessTrip": {
        "type": "object",
        "required": true,
        "description": "行程信息对象",
        "properties": {
          "businessTripDetails": {
            "type": "array",
            "description": "行程详细信息列表",
            "items": {
              "type": "object",
              "properties": {
                "departCityCode": {
                  "type": "string",
                  "description": "出发地城市编码；费控系统城市 cityCode，第一段行程必填"
                },
                "destinationCityCode": {
                  "type": "string",
                  "description": "目的地城市编码"
                },
                "beginTime": {
                  "type": "string",
                  "description": "行程出发时间，格式 yyyy-MM-dd HH:mm；接口会根据行程组件配置的时间精度进行转换"
                },
                "endTime": {
                  "type": "string",
                  "description": "行程结束时间，格式 yyyy-MM-dd HH:mm；接口会根据行程组件配置的时间精度进行转换"
                },
                "travelMode": {
                  "type": "string",
                  "description": "出行方式，支持 Train、Bus、Ship、Hotel、RideHailing、AirPlane、Other；多选时用英文逗号拼接"
                },
                "roundTrip": {
                  "type": "string",
                  "description": "是否往返：N 单程；Y 往返；不传默认 N",
                  "enum": [
                    "N",
                    "Y"
                  ]
                },
                "beginTimePrecision": {
                  "type": "string",
                  "description": "开始时间精度，半天场景下传 AM 或 PM",
                  "enum": [
                    "AM",
                    "PM"
                  ]
                },
                "endTimePrecision": {
                  "type": "string",
                  "description": "结束时间精度，半天场景下传 AM 或 PM",
                  "enum": [
                    "AM",
                    "PM"
                  ]
                },
                "tripReason": {
                  "type": "string",
                  "description": "出差事由；当表单行程组件配置为必填时必传"
                },
                "customArchiveOptionNumbers": {
                  "type": "array",
                  "description": "自定义档案选项编号列表",
                  "items": {
                    "type": "string"
                  }
                },
                "estimateExpenses": {
                  "type": "array",
                  "description": "预估费用列表",
                  "items": {
                    "type": "object",
                    "properties": {
                      "expenseTypeNumber": {
                        "type": "string",
                        "description": "费用类型编码"
                      },
                      "applyAmount": {
                        "type": "string",
                        "description": "申请金额；最多 9 位整数和 2 位小数；不传或传 0 时默认取行程预估金额"
                      },
                      "remark": {
                        "type": "string",
                        "description": "费用备注"
                      },
                      "spreadInfo": {
                        "type": "object",
                        "description": "预估费用分摊信息；当表单开启分摊且开启预付费用时，分摊对象是预估费用",
                        "properties": {
                          "spreadTypeCode": {
                            "type": "string",
                            "description": "分摊方式编码"
                          },
                          "spreadInfoItemList": {
                            "type": "array",
                            "description": "分摊明细列表",
                            "items": {
                              "type": "object",
                              "properties": {
                                "spreadAmount": {
                                  "type": "string",
                                  "description": "分摊明细金额"
                                },
                                "proportion": {
                                  "type": "string",
                                  "description": "分摊明细比例；若产生误差，需要在最后一笔补尾差"
                                },
                                "originalSpreadAmount": {
                                  "type": "string",
                                  "description": "分摊明细原币金额"
                                },
                                "currencyCode": {
                                  "type": "string",
                                  "description": "分摊明细原币币种编码；当前预估费用仅支持 CNY"
                                },
                                "remark": {
                                  "type": "string",
                                  "description": "分摊备注；需表单和分摊方式配置允许填写"
                                },
                                "customSpreadFieldValueList": {
                                  "type": "array",
                                  "description": "自定义分摊字段值列表",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "fieldBizType": {
                                        "type": "string",
                                        "description": "分摊字段业务类型：EMPLOYEE、DEPARTMENT、PROJECT、COSTCENTER、CUSTOMFILE"
                                      },
                                      "fieldCode": {
                                        "type": "string",
                                        "description": "分摊字段编码"
                                      },
                                      "fieldValue": {
                                        "type": "string",
                                        "description": "分摊字段值编码，如员工花名册编码、组织编码、项目编号、成本中心编码或自定义档案选项编码"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "relatedBillId": {
        "type": "number",
        "required": false,
        "description": "费控系统内关联申请单的单据编号"
      },
      "peerEmpNumbers": {
        "type": "array",
        "required": false,
        "description": "同行人员工编号列表，最多 50 个",
        "items": {
          "type": "string"
        }
      },
      "billApplyAuthCheckType": {
        "type": "string",
        "required": false,
        "description": "是否校验单据发起权限：Y 校验，N 不校验；默认 Y",
        "enum": [
          "Y",
          "N"
        ]
      },
      "spreadInfo": {
        "type": "object",
        "required": false,
        "description": "分摊信息；若表单开启分摊且未开启预付费用，则表示整张差旅申请单的分摊",
        "properties": {
          "spreadTypeCode": {
            "type": "string",
            "description": "分摊方式编码，可在系统设置中查看"
          },
          "spreadInfoItemList": {
            "type": "array",
            "description": "分摊明细列表",
            "items": {
              "type": "object",
              "properties": {
                "spreadAmount": {
                  "type": "string",
                  "description": "分摊明细金额"
                },
                "proportion": {
                  "type": "string",
                  "description": "分摊明细比例"
                },
                "originalSpreadAmount": {
                  "type": "string",
                  "description": "分摊明细原币金额"
                },
                "currencyCode": {
                  "type": "string",
                  "description": "分摊明细原币币种编码；当前仅支持 CNY"
                },
                "remark": {
                  "type": "string",
                  "description": "分摊备注；需表单和分摊方式配置允许填写"
                },
                "customSpreadFieldValueList": {
                  "type": "array",
                  "description": "自定义分摊字段值列表",
                  "items": {
                    "type": "object",
                    "properties": {
                      "fieldBizType": {
                        "type": "string",
                        "description": "分摊字段业务类型：EMPLOYEE、DEPARTMENT、PROJECT、COSTCENTER、CUSTOMFILE"
                      },
                      "fieldCode": {
                        "type": "string",
                        "description": "分摊字段编码"
                      },
                      "fieldValue": {
                        "type": "string",
                        "description": "分摊字段值编码"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "responseNotes": [
    "成功时 returnCode 为 SUC0000",
    "body 为新创建的单据编号",
    "success 为 true 时表示创建成功",
    "错误码：E0001 表示具体业务异常提示",
    "联调经验：eventNumber 不是临时流水号，而是表单模板的固定编号；传错时本接口可能返回 ERROR2 和“表单已被删除”",
    "联调经验：部分必填字段会由表单模板自动回填，例如“承担部门/单据部门”；如果外部重复传入，接口可能返回“自定义字段[单据部门]不允许传入，请检查”",
    "联调经验：billStatus=APPRV_PEND 时，如果审批流试算结果包含自选节点，接口会返回“试算结果包含自选节点，无法自动获取审批人”；这种场景可先创建 DRAFT 草稿单，再由前台或后续流程补选审批人"
  ],
  "usageNotes": [
    "创建前建议先通过详情查询或平台配置确认目标表单的 eventNumber，再复用该编号创建新单",
    "如果要按既有单据复制创建，优先复用申请人、eventNumber 和表单允许外部传入的字段，不要盲目透传全部 customFields",
    "新版文档已明确列出 businessTrip.businessTripDetails、estimateExpenses 和 spreadInfo 的结构；构造请求体时建议按这三层对象组织，而不是把子字段平铺到顶层",
    "城市类行程字段建议按以下顺序获取 cityCode：先检查本地是否已有通过“下载城市信息”接口解密得到的城市列表文件；如果没有本地文件，先触发“下载城市信息”接口获取并解密全量城市数据；只有在前两步都不可用时，再回退到“查询所有城市信息”接口做在线定点查询",
    "如果使用本地城市列表文件，优先按城市中文名或英文名离线检索 cityCode；已验证例如福州市为 114、成都市为 255",
    "本接口已联调验证：使用 eventNumber=01260319095833000001、empNumber=0120260009、billStatus=DRAFT 可成功创建测试单"
  ],
  "catalogIndex": {
    "path": "../../index.json"
  }
}
