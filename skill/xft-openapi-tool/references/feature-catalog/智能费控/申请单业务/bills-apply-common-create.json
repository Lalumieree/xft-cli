{
  "id": "bills-apply-common-create",
  "name": "新建通用申请单（草稿、审批通过、审批中）",
  "module": "智能费控",
  "submodule": "申请单业务",
  "operation": "create",
  "resource": "commonApplication",
  "aliases": [
    "新建通用申请单",
    "创建通用申请单",
    "common apply create"
  ],
  "keywords": [
    "通用申请单",
    "创建",
    "eventNumber",
    "empNumber",
    "billStatus",
    "multiPersonCollections"
  ],
  "businessScenarios": [
    "新建草稿通用申请单",
    "新建审批通过通用申请单",
    "新建审批中通用申请单"
  ],
  "description": "新增通用申请单，支持创建草稿、审批通过和审批中三种状态，可携带自定义字段、多人收款和关联申请单。",
  "method": "POST",
  "url": "https://api.cmbchina.com/itrip/xft-api/v1/bills/apply/common/create",
  "requestMode": "json",
  "responseMode": "json",
  "encryptBody": true,
  "decryptResponse": true,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "eventNumber": {
        "type": "string",
        "required": true,
        "description": "单据表单编号"
      },
      "outRelId": {
        "type": "string",
        "required": false,
        "description": "外部单据编号"
      },
      "billCompanyCode": {
        "type": "string",
        "required": false,
        "description": "薪福通法人公司编码"
      },
      "billDepartmentCode": {
        "type": "string",
        "required": false,
        "description": "薪福通部门组织编码"
      },
      "empNumber": {
        "type": "string",
        "required": true,
        "description": "申请人薪福通花名册员工号"
      },
      "billStatus": {
        "type": "string",
        "required": true,
        "description": "单据状态：DRAFT 草稿；APPRV 审批通过；APPRV_PEND 审批中",
        "enum": [
          "DRAFT",
          "APPRV",
          "APPRV_PEND"
        ]
      },
      "customFieldValues": {
        "type": "array",
        "required": false,
        "description": "自定义字段值列表",
        "items": {
          "type": "object",
          "properties": {
            "fieldNumber": {
              "type": "string",
              "description": "自定义字段编号"
            },
            "fieldValue": {
              "type": "string",
              "description": "自定义字段值"
            }
          }
        }
      },
      "multiPersonCollections": {
        "type": "array",
        "required": false,
        "description": "多人收款信息列表",
        "items": {
          "type": "object",
          "description": "单条多人收款信息"
        }
      },
      "relatedBillId": {
        "type": "number",
        "required": false,
        "description": "关联申请单据编号"
      },
      "billApplyAuthCheckType": {
        "type": "string",
        "required": false,
        "description": "是否校验单据发起权限：Y 校验，N 不校验",
        "enum": [
          "Y",
          "N"
        ]
      }
    }
  },
  "responseNotes": [
    "成功时 returnCode 为 SUC0000",
    "body 为新创建的单据编号",
    "错误码：E0001 表示具体业务异常提示"
  ],
  "catalogIndex": {
    "path": "../../index.json"
  }
}
