  "url": "https://api.cmbchina.com/itrip/xft-api/v1/accessory/custom-field/bind",
  "requestMode": "json",
  "responseMode": "json",
  "encryptBody": true,
  "decryptResponse": true,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "billId": {
        "type": "number",
        "required": true,
        "description": "单据编号，所有单据类型和单据状态都支持"
      },
      "fileInfos": {
        "type": "array",
        "required": true,
        "description": "附件信息列表",
        "items": {
          "type": "object"
        }
      }
    }
  },
  "responseNotes": [
    "success 为 true 表示绑定成功",
    "errorMessage 返回绑定失败原因",
    "错误码：200 表示成功"
  ],
  "usageNotes": [
    "通常先调用“单据自定义附件字段附件上传”拿到 fileId，再调用本接口绑定到指定附件字段",
