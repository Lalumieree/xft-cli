{
  "id": "bills-export-pdf",
  "name": "单据打印PDF",
  "module": "智能费控",
  "submodule": "单据文件",
  "operation": "download",
  "resource": "billDocument",
  "aliases": [
    "打印单据 PDF",
    "导出单据 PDF",
    "bill export pdf"
  ],
  "keywords": [
    "单据",
    "PDF",
    "打印",
    "导出",
    "billIds",
    "templateCode",
    "printPattern",
    "invoiceScope"
  ],
  "businessScenarios": [
    "按打印模板导出单据 PDF",
    "打印单据并附带发票或图片附件",
    "导出支付回单和审批附件"
  ],
  "description": "根据打印模板把单据信息导出为 PDF 流，可选附带发票、图片附件、审批附件、支付回单等内容。",
  "method": "POST",
  "url": "https://api.cmbchina.com/itrip/xft-api/v1/bills/exportPDF",
  "requestMode": "json",
  "responseMode": "binary",
  "encryptBody": true,
  "decryptResponse": false,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "billIds": {
        "type": "array",
        "required": true,
        "description": "单据编号列表，目前仅允许一个单据编号",
        "items": {
          "type": "number"
        }
      },
      "printPattern": {
        "type": "array",
        "required": false,
        "description": "打印范围：invoice 发票附件；billAttachment 单据附件；expenseAttachment 费用附件；apprAttachment 审批评论附件；statement 支付回单；img 为全部附件",
        "items": {
          "type": "string"
        }
      },
      "invoiceScope": {
        "type": "array",
        "required": false,
        "description": "发票类型：electronic 电子发票；paper 纸质发票",
        "items": {
          "type": "string"
        }
      },
      "templateCode": {
        "type": "string",
        "required": true,
        "description": "打印模板编码"
      },
      "empSeqId": {
        "type": "number",
        "required": false,
        "description": "当前用户 id"
      },
      "printDetail": {
        "type": "boolean",
        "required": false,
        "description": "是否打印单据详情，默认 true"
      },
      "invoicePrintLayout": {
        "type": "string",
        "required": false,
        "description": "发票打印布局：one 一页一张；two 一页两张；four 一页四张"
      },
      "OPAUID": {
        "type": "string",
        "required": true,
        "description": "薪福通企业号"
      }
    }
  },
  "responseNotes": [
    "成功时返回 PDF 二进制文件流",
    "调用时需要提供 outputPath 才能落盘",
    "错误码：200 表示成功"
  ],
  "usageNotes": [
    "适合归档、打印或调试模板渲染结果",
    "如果只想要主单据 PDF，可不传 printPattern 或只传 printDetail=true"
  ],
  "catalogIndex": {
    "path": "../../index.json"
  }
}
