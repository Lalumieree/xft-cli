{
  "id": "bills-bill-list",
  "name": "批量查询单据列表",
  "module": "智能费控",
  "submodule": "单据查询",
  "operation": "query",
  "resource": "bill",
  "aliases": [
    "查询单据列表",
    "批量查单",
    "bill list"
  ],
  "keywords": [
    "单据列表",
    "批量查询",
    "eventTypes",
    "billStatusList",
    "billIds",
    "eventNumbers",
    "submitEmpNumbers"
  ],
  "businessScenarios": [
    "按业务类型和状态分页查询单据列表",
    "按申请人或提单人筛选单据",
    "按时间范围批量拉取单据基础信息"
  ],
  "description": "根据查询条件分页查询单据基本信息列表，支持申请单、报销单、借还款单、对公单据、财务处理和档案管理等多类业务单据。",
  "method": "POST",
  "url": "https://api.cmbchina.com/itrip/xft-api/v1/bills/bill-list",
  "requestMode": "json",
  "responseMode": "json",
  "encryptBody": true,
  "decryptResponse": true,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "billCompanyCodes": {
        "type": "array",
        "required": false,
        "description": "单据所属法人公司编码",
        "items": {
          "type": "string"
        }
      },
      "billDepartmentCodes": {
        "type": "array",
        "required": false,
        "description": "单据所属部门编码",
        "items": {
          "type": "string"
        }
      },
      "submitEmpNumbers": {
        "type": "array",
        "required": false,
        "description": "提单人花名册编号",
        "items": {
          "type": "string"
        }
      },
      "applyEmpNumbers": {
        "type": "array",
        "required": false,
        "description": "申请人花名册编号",
        "items": {
          "type": "string"
        }
      },
      "eventTypes": {
        "type": "array",
        "required": false,
        "description": "业务类型编码列表，如 TRAVEL_APPLY、COMMON_REIM、TRAVEL_REIM",
        "items": {
          "type": "string"
        }
      },
      "billStatusList": {
        "type": "array",
        "required": false,
        "description": "单据状态编码列表，如 0 草稿、1 待审批、2 审批通过、15 已废弃",
        "items": {
          "type": "string"
        }
      },
      "billSubmitBeginTime": {
        "type": "string",
        "required": false,
        "description": "单据提单起始时间，格式 yyyy-MM-dd hh:mm:ss"
      },
      "billSubmitEndTime": {
        "type": "string",
        "required": false,
        "description": "单据提单终止时间，格式 yyyy-MM-dd hh:mm:ss"
      },
      "billFinishBeginTime": {
        "type": "string",
        "required": false,
        "description": "单据完成起始时间，格式 yyyy-MM-dd hh:mm:ss"
      },
      "billFinishEndTime": {
        "type": "string",
        "required": false,
        "description": "单据完成终止时间，格式 yyyy-MM-dd hh:mm:ss"
      },
      "billIds": {
        "type": "array",
        "required": false,
        "description": "单据编号集合，最多 500 个",
        "items": {
          "type": "number"
        }
      },
      "eventNumbers": {
        "type": "array",
        "required": false,
        "description": "表单编码集合，最多 50 个",
        "items": {
          "type": "string"
        }
      },
      "eventNames": {
        "type": "array",
        "required": false,
        "description": "表单名称集合，最多 50 个",
        "items": {
          "type": "string"
        }
      },
      "printStatusList": {
        "type": "array",
        "required": false,
        "description": "打印状态：1 可打印；0 不可打印",
        "items": {
          "type": "string"
        }
      },
      "signStatusList": {
        "type": "array",
        "required": false,
        "description": "签收状态：N 免签收；W 未签收；F 已签收",
        "items": {
          "type": "string"
        }
      },
      "start": {
        "type": "number",
        "required": false,
        "description": "分页开始条数"
      },
      "limit": {
        "type": "number",
        "required": false,
        "description": "分页条数，不大于 500；不传默认前 500 条"
      }
    }
  },
  "responseNotes": [
    "成功时 returnCode 为 SUC0000",
    "body 为分页查询结果对象，包含单据基础信息列表",
    "错误码：200 表示成功"
  ],
  "usageNotes": [
    "适合先批量圈定 billId，再配合详情接口逐单拉取完整内容",
    "eventTypes 已覆盖申请单和报销单等多类业务，例如 TRAVEL_APPLY、COMMON_APPLY、TRAVEL_REIM、COMMON_REIM",
    "limit 最大 500，做历史补数时建议按时间窗口分页拉取"
  ],
  "catalogIndex": {
    "path": "../../index.json"
  }
}
