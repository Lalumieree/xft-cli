{
  "id": "reimburse-bill-common-create",
  "name": "新建日常报销单（草稿、审批通过、审批中）",
  "module": "智能费控",
  "submodule": "报销单业务",
  "operation": "create",
  "resource": "commonReimbursement",
  "aliases": [
    "新建日常报销单",
    "创建日常报销单",
    "common reimburse create"
  ],
  "keywords": [
    "日常报销单",
    "创建",
    "eventNumber",
    "empNumber",
    "billStatus",
    "reimAmount",
    "expenseList"
  ],
  "businessScenarios": [
    "新建草稿日常报销单",
    "新建审批通过日常报销单",
    "新建审批中日常报销单"
  ],
  "description": "新增日常报销单，支持创建草稿、审批通过和审批中三种状态，可携带单据与费用自定义字段、费用信息和收款信息。",
  "method": "POST",
  "url": "https://api.cmbchina.com/itrip/xft-api/v1/reimburse/bill/create",
  "requestMode": "json",
  "responseMode": "json",
  "encryptBody": true,
  "decryptResponse": true,
  "querySchema": {
    "type": "object",
    "properties": {}
  },
  "bodySchema": {
    "type": "object",
    "properties": {
      "eventNumber": {
        "type": "string",
        "required": true,
        "description": "表单编码"
      },
      "outRelId": {
        "type": "string",
        "required": false,
        "description": "外部关联 id"
      },
      "empNumber": {
        "type": "string",
        "required": true,
        "description": "申请人的花名册员工号"
      },
      "billDepartmentCode": {
        "type": "string",
        "required": false,
        "description": "单据部门编号"
      },
      "billCompanyCode": {
        "type": "string",
        "required": false,
        "description": "单据公司编号"
      },
      "billStatus": {
        "type": "string",
        "required": true,
        "description": "单据状态：DRAFT 草稿；APPRV_PEND 审批中；APPRV 审批通过",
        "enum": [
          "DRAFT",
          "APPRV_PEND",
          "APPRV"
        ]
      },
      "reimAmount": {
        "type": "string",
        "required": true,
        "description": "单据报销总金额"
      },
      "reimAmountCurrencyCode": {
        "type": "string",
        "required": true,
        "description": "单据报销总金额币种，目前只支持 CNY",
        "enum": [
          "CNY"
        ]
      },
      "customFieldValues": {
        "type": "array",
        "required": false,
        "description": "单据自定义字段值列表",
        "items": {
          "type": "object",
          "properties": {
            "fieldNumber": {
              "type": "string",
              "description": "自定义字段编号"
            },
            "fieldValue": {
              "type": "string",
              "description": "自定义字段值"
            }
          }
        }
      },
      "expenseList": {
        "type": "object",
        "required": true,
        "description": "费用信息"
      },
      "billCollectionInfo": {
        "type": "object",
        "required": false,
        "description": "收款信息"
      }
    }
  },
  "responseNotes": [
    "成功时 returnCode 为 SUC0000",
    "body 为新创建的日常报销单编号",
    "错误码：E0001 表示具体业务异常提示"
  ],
  "usageNotes": [
    "eventNumber 和申请单接口一样，应先确认模板固定编号，再发起创建",
    "如果要从旧单复制字段，建议先查详情提取允许外部传入的字段，不要盲目透传全部 customFields"
  ],
  "catalogIndex": {
    "path": "../../index.json"
  }
}
