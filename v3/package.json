{
  "name": "xft-openapi-caller",
  "version": "1.0.0",
  "description": "CLI for matching XFT OpenAPI docs, fetching cached documents, resolving city codes, and calling XFT APIs.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/shenxia_admin/xft-tools.git"
  },
  "homepage": "https://gitee.com/shenxia_admin/xft-tools",
  "bugs": {
    "url": "https://gitee.com/shenxia_admin/xft-tools/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/npm/**"
  ],
  "bin": {
    "xft-find-doc": "dist/npm/xft-find-doc.js",
    "xft-fetch-docs": "dist/npm/xft-fetch-docs.js",
    "xft-call-api": "dist/npm/xft-call-api.js",
